---
// Navbar.astro — navbar render lúc BUILD, song ngữ VI/EN qua <T> (từ điển i18n, JS apply).
import { NAV, PART2_TOPICS, isGroup } from '../data/nav';
import T from './T.astro';

interface Props {
  pageFile?: string;
}
const { pageFile = 'index.html' } = Astro.props;

const isActive = (href: string): boolean =>
  href === pageFile || (href === 'phan-2-chu-de.html' && PART2_TOPICS.has(pageFile));
---

<div class="topbar">
  <a class="topbar__brand" href="index.html">
    <span class="topbar__brand-mark">P</span> PMBOK 8
    <small class="topbar__brand-tag"><T vi="học PMP · v3" en="learn PMP · v3" /></small>
  </a>
  <nav class="topbar__nav">
    {
      NAV.map((item) =>
        isGroup(item) ? (
          <div class="topbar__group">
            <button
              class:list={[
                'topbar__grouptop',
                { 'topbar__grouptop--current': item.children.some((c) => isActive(c.href)) },
              ]}
              type="button"
              aria-haspopup="true"
            >
              <T vi={item.label} en={item.en} />
              <span class="topbar__caret">▾</span>
            </button>
            <div class="topbar__panel">
              {item.children.map((c) => (
                <a
                  class:list={['topbar__panellink', { 'topbar__panellink--current': isActive(c.href) }]}
                  href={c.href}
                >
                  <T vi={c.label} en={c.en} />
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            class:list={['topbar__link', { 'topbar__link--current': isActive(item.href) }]}
            href={item.href}
          >
            <T vi={item.label} en={item.en} />
          </a>
        )
      )
    }
  </nav>
  <div class="topbar__lang" role="group" aria-label="Language / Ngôn ngữ">
    <button class="topbar__langbtn" data-lang-set="vi" type="button">VI</button>
    <button class="topbar__langbtn" data-lang-set="en" type="button">EN</button>
  </div>
  <button class="topbar__menu" id="menuBtn" aria-label="menu">☰</button>
</div>
