---
// Bi.astro — render một chuỗi SONG NGỮ (cả 2 nằm trong DOM, ẩn/hiện qua <html data-lang>).
// Dùng: <Bi k="topicBack" />  (tra từ điển UI)  hoặc  <Bi vi="..." en="..." />  (truyền thẳng).
// Cho phép chuỗi chứa HTML (set:html).
import { UI } from '../i18n/ui';

interface Props {
  k?: string;
  vi?: string;
  en?: string;
}
const { k, vi, en } = Astro.props;
const v = vi ?? (k ? UI.vi[k] : '') ?? '';
const e = en ?? (k ? UI.en[k] : '') ?? '';
---

<span data-l="vi" set:html={v}></span><span data-l="en" set:html={e}></span>
