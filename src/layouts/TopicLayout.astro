---
// TopicLayout.astro — chrome trang chủ đề Phần II (sidebar + hero + footer), render TỪ DATA
// lúc build, SONG NGỮ VI/EN qua <Bi> + từ điển i18n/ui.ts. Thay cho topic-chrome.js.
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Bi from '../components/Bi.astro';
import { TOPICS } from '../data/site';
import { UI } from '../i18n/ui';

interface Props {
  page: string;
  title: string;
}
const { page, title } = Astro.props;

const idx = TOPICS.findIndex((t) => t.id === page);
const t = TOPICS[idx];
const prev = idx > 0 ? TOPICS[idx - 1] : null;
const next = idx < TOPICS.length - 1 ? TOPICS[idx + 1] : null;
---

<BaseLayout title={title} page={page}>
  <Navbar pageFile={`${page}.html`} />
  <div class="shell" id="top">
    <aside class="sidebar" id="side">
      <a class="sidebar__back" href="part-2-topics.html"><Bi k="topicBack" /></a>
      <h4><Bi k="topics" /></h4>
      {
        TOPICS.map((x) => (
          <a href={`${x.id}.html`} class:list={[{ 'is-active': x.id === page }]}>
            <span class="sidebar__num">{x.num}</span>
            {x.short}
          </a>
        ))
      }
      <h4><Bi k="related" /></h4>
      <a href="formulas-and-examples.html"><span class="sidebar__num">∑</span><Bi k="relFormulas" /></a>
      <a href="flashcard-quiz.html"><span class="sidebar__num">?</span><Bi k="relFlashquiz" /></a>
    </aside>
    <main>
      <div class="hero" id="topic-hero">
        <span class="hero__eyebrow">
          <Bi
            vi={`Phần II · Chủ đề ${t.num}/08 — 8 chủ đề kiến thức`}
            en={`Part II · Topic ${t.num}/08 — 8 knowledge topics`}
          />
        </span>
        <h1><Bi vi={t.title} en={t.titleEn} /></h1>
        <p><Bi vi={t.blurb} en={t.blurbEn} /></p>
      </div>
      <section id={page}>
        <slot />
      </section>
      <section id="miniQuiz" class="mini-quiz"></section>
      <footer id="topic-footer">
        <b><Bi vi={`${UI.vi.partII} · ${t.title}`} en={`${UI.en.partII} · ${t.titleEn}`} /></b>
        <Bi k="source" /><br />
        {
          prev && (
            <a href={`${prev.id}.html`}>
              <Bi vi={`← ${prev.title}`} en={`← ${prev.titleEn}`} />
            </a>
          )
        }
        {prev && next && ' · '}
        {
          next ? (
            <a href={`${next.id}.html`}>
              <Bi vi={`${next.title} →`} en={`${next.titleEn} →`} />
            </a>
          ) : (
            <a href="part-3-agile.html">
              <Bi k="nextAgile" />
            </a>
          )
        }
      </footer>
    </main>
  </div>
</BaseLayout>
