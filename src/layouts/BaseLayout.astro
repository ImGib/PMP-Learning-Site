---
// BaseLayout.astro — nguồn DUY NHẤT của <head>. Thay cho assets/partials/head.html
// + scripts/sync-head.mjs: không còn phải "dán tay rồi chạy script đồng bộ".
interface Props {
  title: string;
  page?: string;
}
const { title, page } = Astro.props;
// Mọi link tài nguyên TUYỆT ĐỐI phải prefix bằng base để không vỡ dưới base path.
// Chuẩn hoá luôn có đúng 1 dấu '/' cuối (BASE_URL có thể trả '/PMP-Learning-Site' không slash).
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
---

<!doctype html>
<html lang="vi" data-lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <!-- Áp ngôn ngữ đã lưu THẬT SỚM (trước khi body vẽ) để không nhấp nháy VI↔EN. -->
    <script is:inline>
      (function () {
        try {
          var l = localStorage.getItem('pmp-lang');
          if (l === 'en' || l === 'vi') document.documentElement.dataset.lang = l;
        } catch (e) {}
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={`${base}assets/styles/main.css`} />
  </head>
  <body data-page={page}>
    <slot />
    <!-- Chỉ nạp JS cho phần TƯƠNG TÁC. Navbar + chrome đã render sẵn lúc build. -->
    <script src={`${base}site.js`} type="module"></script>
  </body>
</html>
